{
  "name": "skill-installer",
  "version": "1.0.0",
  "description": "Install Agent Skills from Git repositories",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "skill-installer": "./bin/skill-installer.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "agent-skills",
    "skills",
    "openclaw",
    "cli"
  ],
  "author": "fakeAccount-lab",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "chalk": "^5.4.1",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.27.0",
    "xdg-basedir": "^5.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
